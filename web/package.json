{
	"name": "web",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "bunx -b astro dev",
		"clean": "rm -rf node_modules/.cache dist .astro",
		"nuke": "bun run clean && rm -rf node_modules",
		"preview": "astro preview",
		"check": "astro check",
		"typecheck": "bunx -b tsc --noEmit",
		"astro": "astro",
		"build": "cd ../backend && bunx convex deploy && bunx convex-helpers ts-api-spec --output-file ../web/src/lib/convexApi.ts && cd ../web && bunx -b astro build"
	},
	"dependencies": {
		"@astrojs/starlight": "^0.38.3",
		"astro": "^6.0.1",
		"sharp": "^0.34.2"
	},
	"devDependencies": {
		"@types/bun": "^1.3.12",
		"convex": "^1.37.0"
	}
}